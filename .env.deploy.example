# 复制为仓库根目录 .env.deploy 后使用（勿提交密钥）
# cp .env.deploy.example .env.deploy

# 对外端口（无 nginx 时直接映射容器 8000）
FANGYU_HTTP_PORT=8000

# 启用 gateway profile 时对外 80
# FANGYU_GATEWAY_PORT=80

# 浏览器来源；单机同域托管 UI 时可 *
CORS_ORIGINS=*

# 大模型（也可稍后在 Studio 设置里填）
# DEEPSEEK_API_KEY=
# OPENAI_API_KEY=

# 数据目录在容器内固定 /data（compose volume）
FANGYU_DATA_DIR=/data
FANGYU_SERVE_UI=1
