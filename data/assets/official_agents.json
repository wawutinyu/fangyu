                      "config": {
                        "code": "try:\n    files = ws_list('.')\nexcept NameError:\n    files = []\nok = 'result.txt' in files\nstatus = 'completed' if ok else 'pending'\ntry:\n    ws_save_state({'last_status': status, 'verified': ok})\nexcept NameError:\n    pass\nresult = {'phase': 'verify', 'verified': ok, 'status': status, 'files': files}"
                      }
