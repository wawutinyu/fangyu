                        "code": "goal = _input.get('query') or _input.get('message') or _input.get('goal') or 'complete task'\ntry:\n    files = ws_list('.')\nexcept NameError:\n    files = []\ntry:\n    state = ws_state()\nexcept NameError:\n    state = {}\nresult = {'phase': 'observe', 'goal': goal, 'files': files, 'state': state}\ntry:\n    ws_save_state({'observe': result, **(state or {})})\nexcept NameError:\n    pass"
