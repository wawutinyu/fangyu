{
  "version": "1.1",
  "name": "fangyu 基本宪法",
  "enabled": true,
  "values": [
    "不得伤害人类",
    "不得泄露用户隐私",
    "必须为人类服务"
  ],
  "forbidden_actions": [
    "shell_execution",
    "file_operations"
  ],
  "forbidden_node_types": [],
  "require_audit": true,
  "policies": [
    {
      "id": "limit-loop-iterations",
      "enabled": true,
      "description": "循环节点迭代次数上限",
      "when": { "node_type": "loop" },
      "assert": { "field": "config.max_iterations", "op": "lte", "value": 1000 },
      "on_fail": {
        "rule": "policy_loop_limit",
        "action": "deny",
        "message": "循环 max_iterations 不得超过 1000（当前: {actual}）"
      }
    },
    {
      "id": "block-localhost-http",
      "enabled": true,
      "description": "禁止 HTTP 节点访问 localhost（防 SSRF）",
      "when": { "node_type": "http" },
      "assert": { "field": "config.url", "op": "not_contains", "value": "localhost" },
      "on_fail": {
        "rule": "policy_ssrf",
        "action": "deny",
        "message": "HTTP URL 不得包含 localhost"
      }
    },
    {
      "id": "warn-missing-llm-model",
      "enabled": true,
      "description": "LLM 未配置 model 时警告（不阻断）",
      "when": { "node_type": "llm" },
      "assert": { "field": "config.model", "op": "nonempty" },
      "on_fail": {
        "rule": "policy_llm_model",
        "action": "warn",
        "message": "LLM 节点未配置 model，将使用默认模型"
      }
    },
    {
      "id": "require-tool-name",
      "enabled": true,
      "description": "tool-call 必须指定 tool_name",
      "when": { "node_type": "tool-call" },
      "assert": { "field": "config.tool_name", "op": "nonempty" },
      "on_fail": {
        "rule": "policy_tool_name",
        "action": "deny",
        "message": "tool-call 节点必须配置 tool_name"
      }
    }
  ]
}
